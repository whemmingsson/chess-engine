{
	"name": "chess-engine",
	"version": "1.0.0",
	"private": true,
	"description": "Simple Node.js app compiled from TypeScript with tsc",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"default": "./dist/runtime.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm --dir ../common build && pnpm --dir ../chess-bots build && tsc",
		"dev": "tsx watch src/index.ts",
		"dev:debug": "tsx watch src/Driver.ts",
		"start": "node dist/index.js",
		"clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@chess-engine/chess-bots": "workspace:*",
		"@chess-engine/common": "workspace:*",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1"
	}
}
