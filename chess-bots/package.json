{
  "name": "@chess-engine/chess-bots",
  "private": true,
  "version": "1.0.0",
  "description": "Bot implementations for chess engine integrations.",
  "main": "dist/index.js",
  "exports": {
    "./common/*": {
      "types": "./dist/common/*.d.ts",
      "default": "./dist/common/*.js"
    },
    "./bots/*": {
      "types": "./dist/bots/*.d.ts",
      "default": "./dist/bots/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../common build && tsc -p tsconfig.json",
